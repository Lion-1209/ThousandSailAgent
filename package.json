{
  "name": "agentflow",
  "version": "0.1.0",
  "description": "多 AI Agent 编排框架 — 用声明式 YAML 定义 Agent 协作流程",
  "type": "module",
  "bin": {
    "agentflow": "./dist/cli/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
