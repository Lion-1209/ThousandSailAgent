    "@ai-sdk/openai": "^3.0.67",
    "@clack/prompts": "^1.5.0",
    "ai": "^6.0.0",
    "commander": "^14.0.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.0",
    "sql.js": "^1.14.1",
    "uuid": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
